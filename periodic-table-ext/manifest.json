{
  "manifest_version": 3,
  "name": "Periodic Table",
  "version": "1.0.0",
  "description": "Right-click context menu to open an interactive Periodic Table of Elements.",
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Periodic Table"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
